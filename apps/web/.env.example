# Vite build-time env — kopyala: .env.local (gitignore'da)
# Hepsi boşsa uygulama offline mock/prototip modunda çalışır.

# Backend API (Fly.io). Set edilince canlı mod varsayılan açık.
VITE_API_BASE_URL=

# Supabase Auth (Dashboard > Settings > API). anon key public'tir.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Analytics 4 measurement id (G-XXXXXXXXXX). Boşsa GA yüklenmez.
VITE_GA_MEASUREMENT_ID=

# true → env API adresi olsa bile mock modda başla (offline demo).
VITE_ENABLE_MOCK=
