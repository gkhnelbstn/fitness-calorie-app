# Kopyala: .env  (gerçek .env repoya GİRMEZ — .gitignore'da)

ENVIRONMENT=dev
DEBUG=true

# SQLite (MVP). PostgreSQL'e geçişte:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/fitness
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Open Food Facts (anahtar yok, sadece kendi iletişimini yaz)
OFF_USER_AGENT=fitness-calorie-app/0.1 (kisisel; iletisim: ornek@ornek.com)

# USDA FoodData Central — ücretsiz anahtar al: https://fdc.nal.usda.gov/api-key-signup.html
# DEMO_KEY ile sınırlı test edebilirsin.
USDA_API_KEY=DEMO_KEY

# NVIDIA build.nvidia.com — ücretsiz dev anahtarı (nvapi-...). Boşsa kurallı parser kullanılır.
NVIDIA_API_KEY=
# Güçlü çok-dilli (Türkçe iyi). Alternatif: qwen/qwen2.5-72b-instruct, mistralai/mistral-small-24b-instruct
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Tek kullanıcı API token (Faz 0). Public'e geçişte OAuth2/JWT.
API_TOKEN=dev-local-token

# Spoonacular — free 150 istek/gün. Anahtar al: https://spoonacular.com/food-api/console
# Boşsa /api/admin/import/spoonacular 400 döner.
SPOONACULAR_API_KEY=

# --- Supabase Auth (çok kullanıcı, JWT) ---
# Boşsa JWT doğrulama kapalı → legacy API_TOKEN akışı (lokal dev/test).
# Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ALG=HS256
SUPABASE_JWT_AUDIENCE=authenticated
# Asimetrik (RS256/ES256) projede: https://<proj>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=

# CORS — virgülle ayrılmış ek izinli origin'ler (prod: Vercel domaini).
# localhost:5173 / 127.0.0.1 zaten dev için açık.
CORS_ORIGINS=

# --- Supabase Storage (öğün fotoğrafları; prod) ---
# service_role key — YALNIZ backend secret'ı, asla frontend'e/repoya koyma.
# Boşsa fotolar yerel UPLOAD_DIR'e yazılır (dev/test).
SUPABASE_PROJECT_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=meal-photos
